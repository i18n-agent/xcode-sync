# i18n Agent API key — required for Pull/Push translations
# Get yours at: https://app.i18nagent.ai
#
# The menu bar app reads this from ~/.config/i18nagent/config.json
# To configure, run:  i18nagent login --key YOUR_KEY
#
# Or create the config file manually:
#   mkdir -p ~/.config/i18nagent
#   echo '{"apiKey":"i18n_your_key_here"}' > ~/.config/i18nagent/config.json

I18N_AGENT_API_KEY=i18n_your_key_here
